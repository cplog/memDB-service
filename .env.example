# ───────────────────────────────────────────────
# Hindsight stack (docker-compose / Railway)
# ───────────────────────────────────────────────

HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_LLM_API_KEY=sk-your-openai-key-here

HINDSIGHT_API_DATABASE_URL=postgresql://postgres:password@localhost:5432/hindsight
HINDSIGHT_API_MIGRATION_DATABASE_URL=postgresql://postgres:password@localhost:5432/hindsight
HINDSIGHT_API_VECTOR_EXTENSION=pgvector
HINDSIGHT_API_TEXT_SEARCH_EXTENSION=native
HINDSIGHT_API_WORKER_ID=consultant-main
HINDSIGHT_CONTROL_PLANE_ENABLED=true

POSTGRES_PASSWORD=choose-a-strong-password-here

# ───────────────────────────────────────────────
# Cold start & client scripts (examples/)
# API base URL — NOT the Control Plane dashboard
# ───────────────────────────────────────────────

HINDSIGHT_URL=https://knowledge.crewio.ai
# Quote if the value contains $ (bcrypt keys start with $2)
HINDSIGHT_API_KEY='your-tenant-api-key'

# Control Plane dashboard (browser UI only)
HINDSIGHT_UI_URL=https://hindsight-production-baf0.up.railway.app

# ───────────────────────────────────────────────
# Frontend portal (frontend_platform/.env.local)
# ───────────────────────────────────────────────

# HINDSIGHT_API_URL=https://knowledge.crewio.ai
# HINDSIGHT_UI_URL=https://hindsight-production-baf0.up.railway.app
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# BACKEND_URL=http://localhost:8000

# ───────────────────────────────────────────────
# API backend (backend_platform — also reads root .env)
# ───────────────────────────────────────────────

