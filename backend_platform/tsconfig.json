{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "jose": ["node_modules/jose"],
      "@vectorize-io/hindsight-client": [
        "node_modules/@vectorize-io/hindsight-client"
      ]
    }
  },
  "include": ["src/**/*"]
}
